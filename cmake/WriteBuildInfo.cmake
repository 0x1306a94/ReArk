if(NOT DEFINED OUTPUT_FILE)
    message(FATAL_ERROR "OUTPUT_FILE is required")
endif()

string(TIMESTAMP REARK_BUILD_YEAR "%Y" UTC)
string(TIMESTAMP REARK_BUILD_MONTH "%m" UTC)
string(TIMESTAMP REARK_BUILD_DAY "%d" UTC)
string(TIMESTAMP REARK_BUILD_HOUR "%H" UTC)
string(TIMESTAMP REARK_BUILD_MINUTE "%M" UTC)
string(TIMESTAMP REARK_BUILD_SECOND "%S" UTC)
foreach(BUILD_PART YEAR MONTH DAY HOUR MINUTE SECOND)
    string(REGEX REPLACE "^0" "" REARK_BUILD_${BUILD_PART} "${REARK_BUILD_${BUILD_PART}}")
    if(REARK_BUILD_${BUILD_PART} STREQUAL "")
        set(REARK_BUILD_${BUILD_PART} 0)
    endif()
endforeach()
get_filename_component(OUTPUT_DIR "${OUTPUT_FILE}" DIRECTORY)
file(MAKE_DIRECTORY "${OUTPUT_DIR}")
file(WRITE "${OUTPUT_FILE}" "#pragma once\n\n#define REARK_BUILD_YEAR ${REARK_BUILD_YEAR}\n#define REARK_BUILD_MONTH ${REARK_BUILD_MONTH}\n#define REARK_BUILD_DAY ${REARK_BUILD_DAY}\n#define REARK_BUILD_HOUR ${REARK_BUILD_HOUR}\n#define REARK_BUILD_MINUTE ${REARK_BUILD_MINUTE}\n#define REARK_BUILD_SECOND ${REARK_BUILD_SECOND}\n")
